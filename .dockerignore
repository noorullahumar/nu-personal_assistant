# ============================================
# ENVIRONMENT FILES (NEVER COPY TO IMAGE)
# ============================================
.env
.env.*
!.env.example
*.key
*.pem
*.crt
.secrets/

# ============================================
# VERSION CONTROL
# ============================================
.git/
.gitignore
.gitattributes
.gitmodules
.svn/
.hg/

# ============================================
# DEVELOPMENT FILES
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
README.md
LICENSE
CHANGELOG.md
CONTRIBUTING.md

# ============================================
# DEPENDENCIES (Will be installed in container)
# ============================================
node_modules/
venv/
env/
.venv/
__pycache__/
*.pyc

# ============================================
# LOGS & TEMP
# ============================================
*.log
logs/
*.tmp
*.temp
.cache/
.pytest_cache/
.tox/

# ============================================
# DATA FILES (Use volumes in production)
# ============================================
data/
uploads/
documents/
vector_store/
*.db
*.sqlite
mongodb-data/

# ============================================
# DOCKER FILES (Don't copy docker files into image)
# ============================================
Dockerfile
docker-compose*.yml
docker-compose*.yaml
.dockerignore

# ============================================
# CI/CD
# ============================================
.github/
.gitlab/
.ci/
jenkins/
.gitlab-ci.yml
.travis.yml

# ============================================
# TESTING
# ============================================
tests/
test/
__tests__/
*.test.js
*.spec.js
*.test.py
coverage/
.nyc_output/

# ============================================
# DOCUMENTATION
# ============================================
docs/
*.md
!README.md  # Include README if needed

# ============================================
# BACKUP FILES
# ============================================
*.bak
*.backup
*.old

# ============================================
# OS SPECIFIC
# ============================================
.DS_Store
Thumbs.db
Desktop.ini