# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env and fill all values
# ============================================

# ========== REQUIRED - MUST BE CHANGED ==========
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_32_CHAR_SECRET

# OpenAI API Key
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# MongoDB Connection (use Atlas for production)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/nu_ai_db?retryWrites=true&w=majority

# ========== ENVIRONMENT ==========
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ========== JWT SETTINGS ==========
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== SECURITY ==========
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ========== CORS ==========
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========== FRONTEND ==========
FRONTEND_URL=https://yourdomain.com

# ========== RATE LIMITING ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_CHAT_DAILY=500/day

# ========== EMAIL (Required for password reset) ==========
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com
MAIL_USE_TLS=true

# ========== FILE UPLOADS ==========
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.txt,.doc,.docx

# ========== VECTOR STORE ==========
VECTOR_STORE_PATH=data/vector_store
EMBEDDING_MODEL=text-embedding-ada-002
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ========== DATABASE ==========
DATABASE_NAME=nu_ai_db